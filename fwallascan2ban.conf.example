# =============================================================================
# fwallascan2ban.conf.example
# Configuration file for fwallascan2ban
#
# fwallascan2ban monitors web server log files, detects malicious requests
# based on regex patterns, and automatically blocks offending IP addresses
# by adding them to a Firewalla MSP Target List, which is then enforced
# by a block rule at the Firewalla perimeter.
#
# TOOLING & COMMANDS:
#   fwallascan2ban ships with two binaries:
#
#   fwallascan2ban
#     The main daemon process. Managed via systemd in production.
#     Do not run directly in production — use systemctl instead.
#
#     Direct usage (development/testing only):
#       fwallascan2ban -c /etc/fwallascan2ban/fwallascan2ban.conf
#       fwallascan2ban -c /etc/fwallascan2ban/fwallascan2ban.conf -d  (debug mode)
#
#     Systemd management:
#       systemctl start fwallascan2ban       # Start the daemon
#       systemctl stop fwallascan2ban        # Stop the daemon
#       systemctl restart fwallascan2ban     # Restart the daemon
#       systemctl enable fwallascan2ban      # Enable auto-start on boot
#       systemctl disable fwallascan2ban     # Disable auto-start on boot
#       systemctl status fwallascan2ban      # Show systemd service status
#       journalctl -u fwallascan2ban         # View daemon logs
#       journalctl -u fwallascan2ban -f      # Tail daemon logs live
#
#   fwallascan2ban-client
#     The client CLI tool for querying and controlling the running daemon.
#     Communicates with the daemon via Unix domain socket:
#       /run/fwallascan2ban/fwallascan2ban.sock
#     The daemon must be running for client commands to work.
#
#     Commands:
#       fwallascan2ban-client status
#         Show daemon status including uptime, log file being monitored,
#         lines processed, target list inventory (name, count, capacity),
#         total banned IPs, and IPs approaching the ban threshold.
#
#         Example output:
#           Status:          running
#           PID:             12345
#           Uptime:          2 days, 4 hours
#           Log file:        /var/log/tomcat10/access_log.2026-04-24.log
#           Lines processed: 48291
#           -------------------------------------------
#           Target Lists:    2
#             WebServer-Blocklist    (987/1000 IPs)
#             WebServer-Blocklist-2  (143/1000 IPs)
#           Total banned:    1129
#           -------------------------------------------
#           Pending IPs (not yet banned):
#             45.33.32.156    hits: 2/3
#             203.0.113.45    hits: 1/3
#
#       fwallascan2ban-client banned
#         List all banned IPs across all target lists, with source tag
#         and timestamp. The placeholder IP is shown separately if present.
#
#         Source tags:
#           [auto:name]   - Banned automatically by log pattern matching
#                           (e.g. [auto:tomcat], [auto:safeline])
#           [manual]      - Banned manually via fwallascan2ban-client ban
#           [firewalla]   - Found in Firewalla but not in local db,
#                           added externally via MSP portal or mobile app
#           [placeholder] - Placeholder IP keeping an otherwise empty list alive
#
#         Example output:
#           Banned IPs - WebServer-Blocklist (987/1000)
#           --------------------------------------------
#           1.2.3.4          [auto:tomcat]  2026-04-24 10:32:11
#           5.6.7.8          [manual]       2026-04-24 11:15:43
#           9.10.11.12       [firewalla]   2026-04-23 08:01:55
#
#           Banned IPs - WebServer-Blocklist-2 (143/1000)
#           -----------------------------------------------
#           45.33.32.156     [auto]        2026-04-24 09:14:02
#
#           Total banned: 1130 across 2 lists
#
#       fwallascan2ban-client ban <ip>
#         Manually ban an IP address immediately, bypassing maxretry and
#         ignoreregex. The IP is added to the current target list on
#         Firewalla and recorded in the local db with [manual] source tag.
#
#         Example:
#           fwallascan2ban-client ban 1.2.3.4
#
#       fwallascan2ban-client unban <ip>
#         Remove a banned IP from the Firewalla target list and local db.
#         If removing the IP would leave a target list empty, the placeholder
#         IP is automatically inserted to keep the list alive.
#         If removing the IP would leave the ONLY target list with only the
#         placeholder, a warning is shown and the operation proceeds.
#
#         Example:
#           fwallascan2ban-client unban 1.2.3.4
#
#       fwallascan2ban-client pending
#         List all IPs that have matched failregex patterns but have not yet
#         reached the maxretry threshold. Shows current hit count vs threshold.
#
#         Example output:
#           Pending IPs (not yet banned):
#           ------------------------------
#           45.33.32.156    hits: 2/3
#           203.0.113.45    hits: 1/3
#           198.51.100.22   hits: 1/3
#
#       fwallascan2ban-client reload
#         Reload the configuration file without restarting the daemon.
#         Also triggers an immediate reconciliation pass.
#         Equivalent to sending SIGHUP to the daemon process.
#
# ENVIRONMENT VARIABLES:
#   Sensitive values (msp_domain, msp_token) should be set as environment
#   variables in production. Use the ${VAR_NAME} syntax to reference them.
#   In development, you may substitute literal values directly.
#
#   Example (bash):
#     export FW_MSP_DOMAIN=yourname.firewalla.net
#     export FW_MSP_TOKEN=your_personal_access_token
#
#   In production, set these in the environment file:
#     /etc/fwallascan2ban/fwallascan2ban.env
#   This file is referenced by the systemd service unit and should be
#   chmod 600 to protect your credentials.
#
# COMMENTS:
#   Lines beginning with # are comments and are ignored by the parser.
#   Inline comments are not supported.
#
# FORMAT:
#   Key/value pairs use = as the delimiter.
#   Sections are denoted by [SectionName].
#   Multi-line values (failregex, ignoreregex) are continued by indenting
#   subsequent lines with one or more spaces or tabs.
#
# FILES:
#   Config file:    /etc/fwallascan2ban/fwallascan2ban.conf
#   Env vars file:  /etc/fwallascan2ban/fwallascan2ban.env
#   State database: /var/lib/fwallascan2ban/banned.db
#   Unix socket:    /run/fwallascan2ban/fwallascan2ban.sock
#   Systemd logs:   journalctl -u fwallascan2ban
# =============================================================================


# =============================================================================
# [MSP] - Firewalla Managed Security Portal connection settings
#
# These settings control how fwallascan2ban authenticates and communicates
# with the Firewalla MSP cloud API (https://docs.firewalla.net).
# =============================================================================
[MSP]

# msp_domain - Your Firewalla MSP domain.
# This is the unique domain assigned to your MSP instance, in the format:
#   yourname.firewalla.net
# Found in your browser's address bar when logged into my.firewalla.com.
# Supports ${ENV_VAR} substitution for production deployments.
msp_domain = ${FW_MSP_DOMAIN}

# msp_token - Your Firewalla MSP personal access token.
# Generated in the MSP portal under Account Settings -> Create New Token.
# IMPORTANT: Treat this like a password. Never commit it to source control.
#            Rotate it immediately if it is exposed.
#            You can revoke and regenerate tokens at any time in the portal.
# Supports ${ENV_VAR} substitution for production deployments.
msp_token = ${FW_MSP_TOKEN}

# box_name - The friendly name of your Firewalla box as shown in the MSP portal.
# Used at startup to resolve the box's GID (unique identifier) via the
# GET /v2/boxes API. The GID is required when creating block rules.
# If the name is not found, the program will exit with an error.
box_name = Firewalla


# =============================================================================
# [TargetList] - Firewalla MSP Target List settings
#
# A Target List is a named collection of IP addresses that can be referenced
# by a block rule. fwallascan2ban adds banned IPs to the specified target list.
# The associated block rule then enforces the ban at the Firewalla perimeter.
#
# If the target list fills up (see max_targets), the program automatically
# creates a new numbered list (e.g. WebServer-Blocklist-2) and a corresponding
# new block rule for it.
#
# NOTE: Firewalla requires at least one entry in a target list at all times.
# fwallascan2ban manages this automatically using a placeholder IP (see
# placeholder_ip below). The placeholder is added when a list would otherwise
# become empty, and removed automatically when a real IP is added.
# =============================================================================
[TargetList]

# target_list_name - The base name of the target list to use.
# The program will search existing target lists for an exact name match.
# If overflow lists are created, they will be named with a numeric suffix:
#   WebServer-Blocklist, WebServer-Blocklist-2, WebServer-Blocklist-3, ...
# See target_list_on_missing for behavior when no matching list is found.
target_list_name = WebServer-Blocklist

# target_list_category - The category to assign to newly created target lists.
# Only used when the program creates a new target list.
# Common values: malware, porn, games, social, shopping, edu
# Recommended value for security blocking: malware
target_list_category = malware

# target_list_notes - A description added to newly created target lists.
# Only used when the program creates a new target list.
# Visible in the MSP portal's Target List detail view.
target_list_notes = Blocked by fwallascan2ban

# target_list_on_missing - Behavior when no matching target list is found.
# Options:
#   create  - Automatically create a new target list and associated block rule.
#             The new list will use target_list_name, target_list_category,
#             and target_list_notes defined above.
#   error   - Log an error and exit. Use this if you want to ensure the target
#             list is manually created and configured in MSP before running.
target_list_on_missing = create

# max_targets - Maximum number of IP entries allowed per target list.
# When a target list reaches this limit, the program automatically creates
# a new numbered target list and a new corresponding block rule.
# Firewalla's internal limit may vary; 1000 is a safe conservative value.
# Note: The placeholder IP counts toward this limit.
# Set to 0 for no limit (not recommended).
max_targets = 1000

# placeholder_ip - IP address used to satisfy Firewalla's requirement that
# a target list always contain at least one entry.
# This IP is used when a list would otherwise become empty due to unbanning
# or reconciliation removals.
# Requirements:
#   - Must be a valid IP address format
#   - Should be an IP that will NEVER appear in real traffic
#   - Should be immediately recognizable as a placeholder
# The placeholder is automatically added to the internal ignoreregex so it
# will never be treated as a real ban target.
# The placeholder is automatically removed when a real IP is added to the list.
# Recommended: 192.0.2.1 (RFC 5737 TEST-NET-1, reserved for documentation,
# never routable on the public internet)
placeholder_ip = 192.0.2.1


# =============================================================================
# [Rule] - Firewalla MSP Block Rule settings
#
# A Rule is a firewall policy that enforces blocking of traffic matching a
# target list. One rule is created per target list. If overflow target lists
# are created, a corresponding rule is created for each.
#
# Rules are created via POST /v2/rules. The box GID is resolved automatically
# at startup from box_name.
#
# SCOPE:
#   By default (no scope configured), a rule applies globally to ALL devices
#   on ALL networks managed by the Firewalla box. This is the recommended
#   setting for perimeter blocking of malicious IPs.
#
#   Optionally, scope can be restricted to a specific network or device by
#   uncommenting and setting rule_scope_type and rule_scope_value below.
#   The program resolves names to IDs automatically at startup via the
#   GET /v2/devices API.
# =============================================================================
[Rule]

# rule_name - The base name for the block rule(s) created in MSP.
# Visible in the MSP portal's Rules view.
# Overflow rules are named with a numeric suffix matching their target list:
#   WebServer Block Rule, WebServer Block Rule-2, WebServer Block Rule-3, ...
rule_name = WebServer Block Rule

# rule_action - The action to apply to matching traffic.
# Currently only block and allow are supported by the MSP API.
# This should always be block for this use case.
rule_action = block

# rule_direction - The direction of traffic to block.
# Options:
#   bidirection - Block both inbound and outbound traffic (recommended).
#                 Prevents the banned IP from sending to OR receiving from
#                 any device on your network.
#   inbound     - Block only traffic coming from the banned IP.
#   outbound    - Block only traffic going to the banned IP.
rule_direction = bidirection

# rule_notes - A description added to newly created rules.
# Visible in the MSP portal's Rule detail view.
rule_notes = Blocked by fwallascan2ban

# rule_auto_create - Whether to automatically create a block rule when a new
# target list is created (either on startup or due to overflow).
# Options:
#   true  - Automatically create the rule (recommended).
#   false - Create the target list but not the rule. You will need to
#           manually create the rule in the MSP portal.
rule_auto_create = true

# rule_scope_type - (Optional) Restrict the rule to a specific scope.
# If commented out or omitted, the rule applies globally to all devices
# on all networks (recommended for perimeter blocking).
# Options:
#   network - Restrict to a specific LAN. Resolved by name via GET /v2/devices.
#   device  - Restrict to a specific device. Resolved by name via GET /v2/devices.
#             Note: If multiple devices share the same name, fwallascan2ban will
#             log a warning and use the first match found.
#
# rule_scope_value - The friendly name of the network or device to scope to.
# For network scope, use the LAN name as shown in MSP (e.g. LAN1, LAN2, LAN3).
# For device scope, use the device name as shown in MSP (e.g. My Web Server).
#
# Examples:
#   rule_scope_type = network
#   rule_scope_value = LAN3
#
#   rule_scope_type = device
#   rule_scope_value = My Web Server
#
# rule_scope_type = network
# rule_scope_value = LAN3


# =============================================================================
# LOG SOURCES — [Log:name] sections
#
# Each [Log:name] section defines one log source to monitor. You can have up
# to 8 sources in a single daemon instance. Each source has its own:
#   - log_pattern: the file path (strftime codes supported for rotation)
#   - maxretry: hit threshold before banning (default: 3)
#   - log_scan_interval: seconds between directory scans for log rotation
#   - failregex: one or more patterns to match; each must contain <HOST>
#
# Ban source tags: bans are tagged [auto:name] (e.g. [auto:tomcat])
#
# SINGLE LOG SOURCE EXAMPLE (Tomcat only)
# =============================================================================

[Log:tomcat]

# log_pattern - Path to the log file. Supports strftime date codes.
# Tomcat daily rotation example (adjust for your Tomcat version/config):
log_pattern = /var/log/tomcat10/access_log.%Y-%m-%d.log

# maxretry - Hits before banning (counted since daemon start, no time window).
maxretry = 3

# log_scan_interval - How often (seconds) to scan the log directory for a
# newer file (handles log rotation). Set to 0 to disable directory scanning
# and rely on inotify events only.
# log_scan_interval = 60

# failregex - Patterns that identify malicious requests.
# Each pattern must contain <HOST> to capture the IP to potentially ban.
# Continuation lines must be indented with one or more spaces or tabs.
failregex = ^<HOST> - - \[.*\] "(GET|POST|HEAD|PROPFIND|CONNECT) .*\.(php|env|git|cgi|sh|sql|asp|aspx).*"
            ^<HOST> - - \[.*\] "(GET|POST|HEAD|PROPFIND|CONNECT) .*/(wp-admin|blog|shop|cms|wp-content|wp-includes|config|setup|license|SDK|geoserver|admin|well-known|cgi-bin|actuator|hnap|developmentserver|metadata|backup|old|wp|wordpress|new|boaform|.well-known).*"
            ^<HOST> - - \[.*\] "(GET|POST|HEAD|PROPFIND|CONNECT) .*(mcp|boaform|xmlrpc|sonicos|sslvpn|sonicui|auth1?\.html).*"
            ^<HOST> - - \[.*\] "CONNECT .*"
            ^<HOST> - - \[.*\] "OPTIONS .*"
            ^<HOST> - - \[.*\] "-" 400 (?:-|\d+)
            ^<HOST> - - \[.*\] "POST / HTTP/1.1" 200
            ^<HOST> - - \[.*\] "GET /\[.\][a-zA-Z0-9].*" 404
            ^<HOST> - - \[.*\] "GET .*/manager/html.*" 401 \d+
            ^<HOST> - - \[.*\] "GET .*/remote/login.*" 401 \d+


# =============================================================================
# MULTI-SOURCE EXAMPLE — Tomcat + SafeLine WAF
#
# Uncomment this section if you are also monitoring SafeLine WAF attack logs.
# Requires the safeline-poll timer (make install-safeline) to poll the
# SafeLine API and write denied-IP events to attacks.log.
#
# With maxretry=1, every SafeLine block triggers an immediate ban.
# Bans from this source are tagged [auto:safeline] in the banned list.
# =============================================================================
# [Log:safeline]
# log_pattern        = /var/log/safeline-waf/attacks.log
# maxretry           = 1
# log_scan_interval  = 0
# failregex          = "src_ip":"<HOST>"[^}]*"action":"deny"


# =============================================================================
# [Reconciliation] - Startup and periodic reconciliation behavior
#
# Controls how fwallascan2ban handles discrepancies between the local
# banned.db state file and the Firewalla target lists.
#
# Reconciliation runs:
#   - Automatically on startup
#   - When triggered via: fwallascan2ban-client reload
#   - Periodically based on reconcile_interval
#
# The reconciliation process:
#   1. Loads local banned.db into memory
#   2. Fetches all matching target lists from Firewalla
#   3. Builds a master deduped IP set across all lists
#   4. Resolves discrepancies per the options below
#   5. Verifies block rules exist for each target list
#   6. Consolidates lists if space has opened up
#   7. Logs a reconciliation summary
# =============================================================================
[Reconciliation]

# reconcile_interval - How often to run reconciliation while the daemon is
# running, in seconds. Set to 0 to only reconcile on startup and reload.
# Examples:
#   0    - Only on startup and reload
#   3600 - Once per hour (recommended)
#   86400 - Once per day
reconcile_interval = 3600

# on_duplicate_ip - What to do when the same IP appears in more than one
# Firewalla target list.
# Options:
#   remove - Remove the duplicate, keeping the IP only in the lowest
#            numbered list (recommended)
#   keep   - Leave duplicates in Firewalla, deduplicate in memory only
#   error  - Log error and exit
on_duplicate_ip = remove

# on_ip_in_firewalla_not_db - What to do when an IP exists in a Firewalla
# target list but has no corresponding entry in the local banned.db.
# This typically means it was added manually via the MSP portal or mobile app.
# Options:
#   add    - Add to local db with [firewalla] source tag (recommended)
#   remove - Remove the IP from Firewalla
#   error  - Log error and exit
on_ip_in_firewalla_not_db = add

# on_ip_in_db_not_firewalla - What to do when an IP exists in the local
# banned.db but is missing from all Firewalla target lists.
# This could mean it was manually removed via the MSP portal or mobile app.
# Options:
#   add    - Re-add the IP to Firewalla automatically (recommended)
#   remove - Remove the IP from local db entirely
#   error  - Log error and exit
on_ip_in_db_not_firewalla = add

# on_missing_rule - What to do when a target list exists on Firewalla but
# has no corresponding block rule.
# Options:
#   create - Automatically create the missing block rule (recommended)
#   error  - Log error and exit
on_missing_rule = create

# on_list_consolidation - What to do when removals during reconciliation
# create free space in earlier target lists while later overflow lists exist.
# Options:
#   consolidate - Move IPs from higher numbered lists into available space
#                 in lower numbered lists. Empty overflow lists and their
#                 rules are deleted from Firewalla. The placeholder IP is
#                 used to protect any list that would otherwise become empty
#                 during the process. (recommended)
#   ignore      - Leave lists as-is, just update in-memory capacity tracking
#   error       - Log error and exit
on_list_consolidation = consolidate


# =============================================================================
# [Filters] - Global ignore list
#
# ignoreregex:
#   One or more IP addresses or CIDR ranges to never ban, one per line.
#   Continuation lines must be indented with at least one space or tab.
#   IPs matching any entry here are silently ignored even if they match
#   a failregex pattern in any log source. List your own IPs, internal
#   networks, and trusted addresses here to prevent accidental self-banning.
#   Supports:
#     - Single IPv4 addresses:  192.168.1.1
#     - IPv4 CIDR ranges:       192.168.1.0/24
#     - IPv6 loopback:          ::1
#     - IPv4 loopback:          127.0.0.1
#   Note: The placeholder_ip is automatically added to the internal
#   ignoreregex at startup and does not need to be listed here.
# =============================================================================
[Filters]

# ignoreregex - IP addresses and CIDR ranges to never ban.
# Add your own public IP, all internal LAN ranges, and any other trusted
# addresses here. This prevents accidental self-banning during testing
# or if your own traffic triggers a failregex pattern.
ignoreregex = 127.0.0.1
              ::1
              192.168.1.0/24
              192.168.2.0/24
              192.168.3.0/24
