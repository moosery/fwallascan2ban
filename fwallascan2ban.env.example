# =============================================================================
# fwallascan2ban.env.example
# Environment variables for fwallascan2ban
#
# Copy this file to /etc/fwallascan2ban/fwallascan2ban.env
# and set the values below.
#
# IMPORTANT: This file contains sensitive credentials.
#            Set permissions immediately after copying:
#              chmod 600 /etc/fwallascan2ban/fwallascan2ban.env
#
# This file is loaded by both systemd service units via EnvironmentFile=:
#   fwallascan2ban.service  — reads FW_MSP_DOMAIN, FW_MSP_TOKEN
#   safeline-poll.service   — reads SAFELINE_API_TOKEN, SAFELINE_HOST
# =============================================================================

# -----------------------------------------------------------------------------
# Firewalla MSP credentials (required)
# -----------------------------------------------------------------------------

# FW_MSP_DOMAIN - Your Firewalla MSP domain.
# Found in your browser's address bar when logged into my.firewalla.com.
# Format: yourname.firewalla.net
FW_MSP_DOMAIN=yourname.firewalla.net

# FW_MSP_TOKEN - Your Firewalla MSP personal access token.
# Generated in the MSP portal under Account Settings -> Create New Token.
# Rotate this immediately if it is ever exposed.
FW_MSP_TOKEN=your_personal_access_token_here

# -----------------------------------------------------------------------------
# SafeLine WAF poller credentials (required only if using make install-safeline)
# -----------------------------------------------------------------------------

# SAFELINE_API_TOKEN - Your SafeLine open platform API token.
# Generated in the SafeLine console under System -> Open Platform.
# You only get to see the token once at creation time — store it here immediately.
# Rotate it in the SafeLine console if it is ever exposed.
#SAFELINE_API_TOKEN=your_safeline_api_token_here

# SAFELINE_HOST - IP address or hostname of your SafeLine WAF VM.
# No default — must be set explicitly.
#SAFELINE_HOST=10.0.0.1

# SAFELINE_PORT - SafeLine API port. Only set this if your SafeLine instance
# runs on a non-standard port. Default is 9443.
#SAFELINE_PORT=9443
